# ==========================================
# SERVER CONFIGURATION
# ==========================================
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# ==========================================
# MONGODB ATLAS
# ==========================================
# Get this from MongoDB Atlas > Connect > Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/student_management?retryWrites=true&w=majority

# ==========================================
# JWT AUTHENTICATION
# ==========================================
# Use a long, random, secret string (min 32 characters). Generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRE=7d

JWT_REFRESH_SECRET=replace_with_another_long_random_secret_string
JWT_REFRESH_EXPIRE=30d

# ==========================================
# BCRYPT
# ==========================================
BCRYPT_SALT_ROUNDS=10

# ==========================================
# NODEMAILER (Gmail SMTP example - use an App Password, not your real password)
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
FROM_NAME=Student Management System
FROM_EMAIL=your_email@gmail.com

# OTP settings
OTP_EXPIRE_MINUTES=10

# ==========================================
# CLOUDINARY (Image Uploads)
# ==========================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ==========================================
# ADMIN SEED (used by npm run seed to create the first admin)
# ==========================================
ADMIN_NAME=Super Admin
ADMIN_EMAIL=admin@sms.com
ADMIN_PASSWORD=Admin@12345
